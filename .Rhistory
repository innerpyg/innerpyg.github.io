def print_min_hamming_distance(seq1, seq2):
seq_len1 = len(seq1)
seq_len2 = len(seq2)
hamming_distance={}
for pos in range(seq_len1-seq_len2+1):
check=''
count=0
for base in range(seq_len2):
check = seq1[pos+base]
if seq2[base] != check:
count+=1
hamming_distance[pos] = count
min_seq_index = [k+1 for k,v in hamming_distance.items() if min(hamming_distance.values()) == v]
return(min_seq_index)
def read_seq(file_name):
seq = []
with open(file_name, 'r') as f:
for line in f:
line = line.strip()
seq.append(line)
return "".join(seq)
if __name__ == "__main__":
f_seq1 = 'data/seq1.txt'
f_seq2 = 'data/seq2.txt'
seq1 = read_seq(f_seq1)
seq2 = read_seq(f_seq2)
min_ham_distance_list = print_min_hamming_distance(seq1, seq2)
print(f"가장 낮은 hamming distance를 가지는 Seq2의 Seq1 상의 위치는 : { min_ham_distance_list } 입니다.")
